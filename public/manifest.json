{
  "manifest_version": 3,
  "name": "COLORUI",
  "version": "0.1.0",
  "permissions": [
    "scripting",
    "activeTab",
    "tabs",
    "downloads",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": false  
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_icon": {
      "16": "webbit.png"
    }
  }
}
